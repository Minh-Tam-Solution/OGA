# NQH Creative Studio — Local Mode Configuration
# Copy this file to .env.local and adjust values for your environment.
#
#   cp .env.local.example .env.local

# ── Provider Mode ─────────────────────────────────────────────
# "true" = local inference (zero cloud API cost)
# "false" or unset = Muapi.ai cloud API
NEXT_PUBLIC_LOCAL_MODE=true

# ── Local Inference Server ────────────────────────────────────
# URL of the local FastAPI/mflux server (server-side only, not exposed to browser)
LOCAL_API_URL=http://localhost:8000

# ── Cloud API (disabled in local mode) ────────────────────────
# Uncomment and set if using Muapi.ai cloud mode:
# MUAPI_API_KEY=your-muapi-api-key-here

# ── App Branding ──────────────────────────────────────────────
# Override display name (defaults to "NQH Creative Studio")
# NEXT_PUBLIC_APP_NAME=NQH Creative Studio
